# AgriChain Environment Configuration
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Brave Search API Configuration (Optional)
# Get your API key from: https://api.search.brave.com
BRAVE_API_KEY=your-brave-api-key-here

# Resend Email API Configuration (Optional)
# For email functionality, get your API key from: https://resend.com/api-keys
# In demo mode (default), the backend simulates email sending without actually sending
RESEND_API_KEY=re_your-resend-api-key-here

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Demo mode: Set to True to simulate email sending without Resend API
# Set to False to actually send emails (requires RESEND_API_KEY)
DEMO_MODE=True
